{% assign lang = site.lang | split: '-' | first %}

{% case lang %}
  {% when 'pt' %}
    {% assign lang = site.lang %}

  {% when 'zh' %}
    {% assign lang_last = site.lang | split: '-' | last %}
    {% case lang_last %}
      {% when 'cn', 'sg', 'my', 'hans' %}
        {% assign lang = 'cn' %}
      {% when 'tw', 'hk', 'mo', 'hant' %}
        {% assign lang = 'zh-tw' %}
    {% endcase %}

    {% comment %} Add a new language using when... if needed {% endcomment %}
    {% comment %} If you still encounter language-display issues, check the available locale codes in github-readme-stats (different from ISO-639 standard used in your website) {% endcomment %}
    {% comment %} https://github.com/anuraghazra/github-readme-stats?tab=readme-ov-file#available-locales {% endcomment %}
{% endcase %}

<div class="repo p-2 text-center">
  <a href="https://github.com/{{ include.username }}">
    <div class="only-light">
      <div
        class="my-3"
        style="
          display:grid;
          grid-template-columns:repeat(2,minmax(0,1fr));
          gap:12px;
          max-width:960px;
          width:150%;
          margin:0 auto;
          align-items:start;
          justify-items:center;
        "
      >
        <div style="grid-column:1 / span 2;width:100%;text-align:center;">
          <img
            alt="{{ include.username }} profile details"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/profile-details?username={{ include.username }}&theme=default"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} stats"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/stats?username={{ include.username }}&theme=default"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} productive time"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/productive-time?username={{ include.username }}&theme=default&utcOffset=8"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} top languages"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/most-commit-language?username={{ include.username }}&theme=default"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} repos per language"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/repos-per-language?username={{ include.username }}&theme=default"
          >
        </div>
      </div>
    </div>

    <div class="only-dark">
      <div
        class="my-3"
        style="
          display:grid;
          grid-template-columns:repeat(2,minmax(0,1fr));
          gap:12px;
          max-width:960px;
          width:150%;
          margin:0 auto;
          align-items:start;
          justify-items:center;
        "
      >
        <div style="grid-column:1 / span 2;width:100%;text-align:center;">
          <img
            alt="{{ include.username }} profile details"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/profile-details?username={{ include.username }}&theme=gotham"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} stats"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/stats?username={{ include.username }}&theme=gotham"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} productive time"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/productive-time?username={{ include.username }}&theme=gotham&utcOffset=8"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} top languages"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/most-commit-language?username={{ include.username }}&theme=gotham"
          >
        </div>
        <div style="width:100%;text-align:center;">
          <img
            alt="{{ include.username }} repos per language"
            style="width:100%;height:auto;object-fit:contain;"
            src="https://github-profile-summary-cards.vercel.app/api/cards/repos-per-language?username={{ include.username }}&theme=gotham"
          >
        </div>
      </div>
    </div>
  </a>
</div>
